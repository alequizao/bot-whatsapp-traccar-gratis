PORT=3000
NODE_ENV=production
LOG_LEVEL=info
ADMIN_TOKEN=troque-este-token

TRACCAR_BASE_URL=http://SEU_SERVIDOR:8082
TRACCAR_USER=SEU_USUARIO
TRACCAR_PASS=SUA_SENHA
TRACCAR_POLL_ENABLED=true
TRACCAR_POLL_INTERVAL_MS=10000
